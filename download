#!/usr/bin/env bash
# scripts/run_full_assessment.sh
# Cyber&Legal · Full Multi-Framework Assessment Runner
# ====================================================
# Runs COMPL-AI + OWASP + NIST + ENISA and generates HTML report

set -e

# Load environment variables
if [ -f ".env" ]; then
  export $(grep -v '^#' .env | xargs)
fi

MODEL="${COMPLAI_MODEL:-openai/gpt-4o-mini}"
LIMIT="${COMPLAI_LIMIT:-20}"
PROVIDER="${MODEL_PROVIDER:-openai}"
MODEL_SHORT="${MODEL##*/}"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
OUTPUT_DIR="reports/output"
TITLE="AI Governance Assessment — ${MODEL_SHORT} — ${TIMESTAMP}"

echo ""
echo "╔══════════════════════════════════════════════════════════╗"
echo "║  Cyber&Legal · Full AI Governance Assessment              ║"
echo "╚══════════════════════════════════════════════════════════╝"
echo "  Model    : $MODEL"
echo "  Provider : $PROVIDER"
echo "  Limit    : $LIMIT samples per benchmark"
echo "  Output   : $OUTPUT_DIR"
echo ""

mkdir -p "$OUTPUT_DIR" reports/raw

# ── Step 1: COMPL-AI (EU AI Act Benchmarks) ──────────────────────────────────
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Step 1/4: COMPL-AI — EU AI Act Evaluation"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

source compl-ai/.venv/bin/activate 2>/dev/null || true

python assessments/compl_ai_runner.py \
  --model "$MODEL" \
  --tasks all \
  --limit "$LIMIT" \
  --results-dir reports/raw \
  --output "$OUTPUT_DIR/assessment_summary.json"

deactivate 2>/dev/null || true

# ── Step 2: OWASP LLM Top 10 ─────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Step 2/4: OWASP LLM Top 10 (2025 Edition)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

python assessments/owasp_llm_assessor.py \
  --model "$MODEL_SHORT" \
  --provider "$PROVIDER" \
  --output "$OUTPUT_DIR/owasp_assessment.json"

# ── Step 3: NIST AI RMF (non-interactive mode for CI) ────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Step 3/4: NIST AI RMF Assessment"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ -f "assessments/nist_answers.json" ]; then
  python assessments/nist_rmf_mapper.py \
    --input assessments/nist_answers.json \
    --output "$OUTPUT_DIR/nist_assessment.json"
  echo "  ✅ NIST assessment complete (from pre-filled answers)"
else
  echo "  ℹ️  No nist_answers.json found — run interactively:"
  echo "      python assessments/nist_rmf_mapper.py --interactive"
  echo "  Creating placeholder..."
  echo '{"meta":{"tool":"Cyber&Legal NIST Assessor","note":"Run --interactive to complete"},"scores":{"overall_nist_score":null,"overall_maturity":"NOT ASSESSED","functions":{}}}' > "$OUTPUT_DIR/nist_assessment.json"
fi

# ── Step 4: ENISA Threat Landscape (non-interactive for CI) ──────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Step 4/4: ENISA AI Threat Landscape"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ -f "assessments/enisa_answers.json" ]; then
  python assessments/enisa_threat_evaluator.py \
    --output "$OUTPUT_DIR/enisa_assessment.json"
  echo "  ✅ ENISA assessment complete"
else
  echo "  ℹ️  Run interactively: python assessments/enisa_threat_evaluator.py --interactive"
fi

# ── Generate HTML Report ──────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Generating HTML Report"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

python scripts/generate_report.py \
  --title "$TITLE" \
  --model "$MODEL" \
  --output "$OUTPUT_DIR/assessment_report.html"

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║  ✅ Assessment Complete!                          ║"
echo "╚══════════════════════════════════════════════════╝"
echo "  Report: $OUTPUT_DIR/assessment_report.html"
echo "  Open  : open $OUTPUT_DIR/assessment_report.html"
echo ""
